# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=bookit
POSTGRES_USER=bookit
POSTGRES_PASSWORD=bookit123

# ── Backend ──────────────────────────────────────────────────────────────────
# Full JDBC URL — uses the Docker Compose service name "db"
DATABASE_URL=jdbc:postgresql://db:5432/bookit

# Spring Boot server port (inside the container)
PORT=8080
